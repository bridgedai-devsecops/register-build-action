{
  "name": "@bridgedai/register-build-action",
  "version": "1.0.0",
  "private": false,
  "description": "Register the current GitHub Actions workflow run as a Bridged build (POST /v1/builds/ensure).",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "node ../../private/actions-dev/node_modules/jest/bin/jest.js --config ../../private/actions-dev/jest.config.cjs --selectProjects register-build-action --coverage --passWithNoTests",
    "build": "ncc build src/index.ts -o dist --minify --no-source-map-register",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@bridgedai/actions-core": "file:../../private/actions-dev/packages/bridgedai-actions-core"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.9.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.8.1"
  },
  "license": "MIT",
  "overrides": {
    "undici": "^6.25.0"
  }
}
